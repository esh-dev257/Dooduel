{
  "name": "dooduel-server",
  "version": "1.0.0",
  "description": "Multiplayer drawing game backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"nodemon server.js\" \"npm run dev:client\" --names \"server,client\" --prefix-colors \"cyan,magenta\"",
    "dev:client": "cd client && npm start",
    "postinstall": "cd client && npm install",
    "build": "cd client && npm run build",
    "build-client": "cd client && npm run build",
    "setup": "npm install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@hackernoon/pixel-icon-library": "^1.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
